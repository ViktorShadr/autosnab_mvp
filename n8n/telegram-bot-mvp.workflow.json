    },
    {
      "id": "check-latest-1",
      "name": "Check Latest Upload",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 580],
      "onError": "continueErrorOutput",
      "parameters": {
        "method": "GET",
        "url": "={{ $('Workflow Config').item.json.backendBaseUrl }}/api/v1/invoice-review/bot/uploads/latest",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "chat_id", "value": "={{$('Normalize Update').item.json.chat_id}}" }
