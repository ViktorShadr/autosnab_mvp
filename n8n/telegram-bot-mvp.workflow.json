    {
      "parameters": {
        "operation": "get",
        "tableId": "telegram_bot_sessions",
        "filters": {
          "conditions": [
            {
              "keyName": "chat_id",
              "condition": "eq",
              "keyValue": "={{$json.chatId}}"
            }
          ]
        }
      },
      "id": "load-session-for-file",
      "name": "Load Session For File",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1,
      "position": [
        1030,
        240
      ]
    },
    {
      "parameters": {
        "jsCode": "const session = $json.data?.[0] || {};\nconst files = JSON.parse(session.files_json || '[]');\nfiles.push({ fileId: $json.fileId, fileName: $json.fileName, addedAt: new Date().toISOString() });\nreturn [{ json: { ...$json, sessionRowId: session.id, filesJson: JSON.stringify(files), filesCount: files.length } }];"
      },
      "id": "append-file-to-session",
      "name": "Append File To Session",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
        240
      ]
    },
    {
      "parameters": {
        "operation": "update",
        "tableId": "telegram_bot_sessions",
        "rowId": "={{$json.sessionRowId}}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "files_json": "={{$json.filesJson}}",
            "status": "collecting"
          }
        }
      },
      "id": "store-appended-file",
      "name": "Store Appended File",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1,
      "position": [
        1530,
        240
      ]
    },
    {
      "parameters": {
