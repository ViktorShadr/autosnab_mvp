        "jsCode": "return [{ json: { reply_text: 'Сначала пришлите хотя бы одну страницу документа.' } }];"
      }
    },
    {
      "id": "reply-processing-1",
      "name": "Reply Processing Started",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 300],
      "parameters": {
        "jsCode": "return [{ json: { reply_text: 'Принял, обрабатываю документ...' } }];"
