      "id": "load-session-finalize",
      "name": "Load Session Finalize",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1,
      "position": [
        1030,
        380
      ]
    },
    {
      "parameters": {
        "jsCode": "const session = $json.data?.[0] || {};\nconst files = JSON.parse(session.files_json || '[]');\nif (!files.length) {\n  return [{ json: { ...$json, finalizeError: 'В сессии нет файлов.' } }];\n}\nreturn [{ json: { ...$json, sessionRowId: session.id, files, filesCount: files.length } }];"
      },
      "id": "prepare-finalize",
      "name": "Prepare Finalize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
        380
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "leftValue": "={{$json.finalizeError || ''}}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-finalize-error",
