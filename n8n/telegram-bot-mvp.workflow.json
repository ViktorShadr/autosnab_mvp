      "id": "upload-to-backend-contract",
      "name": "Upload To Backend Contract",
      "notesInFlow": true,
      "notes": "Replace this node's multipart body with the real downloaded Telegram binaries. The current scaffold freezes the metadata contract and session flow, but file download + binary attachment still must be wired in the target n8n instance.",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
