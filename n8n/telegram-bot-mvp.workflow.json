      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Bot API Key"
        }
      }
    },
    {
      "id": "reply-reset-done-1",
      "name": "Reply Reset Done",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 680],
      "parameters": {
        "jsCode": "return [{ json: { reply_text: 'Черновик очищен.' } }];"
      }
