    {
      "id": "if-has-draft-1",
      "name": "If Has Draft",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [480, 500],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose" },
          "combinator": "and",
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json.draft !== null && $json.draft !== undefined }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "reply-draft-status-1",
      "name": "Reply Draft Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 440],
