    {
      "id": "reply-menu-1",
      "name": "Reply Menu",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 800],
      "parameters": {
        "jsCode": "return [{ json: { reply_text: 'Пришлите фото или PDF накладной — можно несколько страниц подряд.\\nКогда все страницы отправлены — нажмите кнопку «Готово» внизу экрана.\\nКнопка «Статус» покажет, что сейчас происходит с документом.\\nКнопка «Сбросить» очистит незавершенный черновик.' } }];"
      }
    },
    {
      "id": "send-reply-1",
      "name": "Send Reply",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1680, 500],
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{$('Normalize Update').item.json.chat_id}}",
        "text": "={{$json.reply_text}}",
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Telegram Bot"
        }
      }
    }
  ],
  "connections": {
    "Telegram Trigger": { "main": [[{ "node": "Workflow Config", "type": "main", "index": 0 }]] },
    "Workflow Config": { "main": [[{ "node": "Normalize Update", "type": "main", "index": 0 }]] },
    "Normalize Update": { "main": [[{ "node": "If Is File", "type": "main", "index": 0 }]] },
    "If Is File": {
      "main": [
        [{ "node": "Get Telegram File", "type": "main", "index": 0 }],
        [{ "node": "If Is Done", "type": "main", "index": 0 }]
      ]
