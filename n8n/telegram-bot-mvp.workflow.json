      "typeVersion": 4.2,
      "position": [0, 120],
      "parameters": {
        "method": "POST",
        "url": "={{ $('Workflow Config').item.json.backendBaseUrl }}/api/v1/invoice-review/bot/drafts/pages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            { "parameterType": "formData", "name": "chat_id", "value": "={{$('Normalize Update').item.json.chat_id}}" },
            { "parameterType": "formData", "name": "source_user_id", "value": "={{$('Normalize Update').item.json.user_id}}" },
            { "parameterType": "formData", "name": "source_username", "value": "={{$('Normalize Update').item.json.username}}" },
            { "parameterType": "formBinaryData", "name": "file", "inputDataFieldName": "data" }
          ]
        },
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Bot API Key"
        }
      }
    },
    {
      "id": "if-unsupported-1",
      "name": "If Page Unsupported",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [240, 120],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose" },
          "combinator": "and",
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{$json.status === 'unsupported_format'}}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "reply-unsupported-1",
      "name": "Reply Unsupported",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 40],
      "parameters": {
        "jsCode": "return [{ json: { reply_text: $json.message || 'Этот формат пока не поддерживается. Пришлите JPG, PNG или PDF.' } }];"
      }
    },
    {
      "id": "reply-page-added-1",
      "name": "Reply Page Added",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 200],
      "parameters": {
        "jsCode": "return [{ json: { reply_text: `Страница ${$json.pages_count} добавлена. Пришлите ещё страницы накладной или нажмите «Готово», если это всё.` } }];"
      }
    },
    {
      "id": "if-is-done-1",
      "name": "If Is Done",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [-240, 400],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "loose" },
          "combinator": "and",
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{$json.intent === 'done'}}",
              "rightValue": true,
