    {
      "parameters": {
        "jsCode": "const source = $json;\nconst status = source.status;\nlet replyText = 'Документ отправлен в обработку.';\nif (status === 'unsupported_format') {\n  replyText = source.message || 'Формат файла пока не поддерживается.';\n} else if (status === 'accepted_for_processing') {\n  replyText = `Документ отправлен в обработку.\\nНомер загрузки: ${source.upload_id}`;\n}\nreplyText += '\\n\\nПроверить результат: «Статус».';\nreturn [{ json: { ...source, replyText } }];"
      },
