      "id": "poll-backend-status",
      "name": "Poll Backend Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1500,
        700
      ]
    },
    {
      "parameters": {
        "jsCode": "const source = $json;\nlet text = source.message || 'Статус обновлён.';\nif (source.status === 'processing' || source.status === 'accepted_for_processing') {\n  text = 'Документ ещё обрабатывается.';\n} else if (source.status === 'processed' || source.status === 'transferred_to_review') {\n  text = 'Документ обработан.';\n} else if (source.status === 'requires_review') {\n  text = 'Документ требует проверки оператором.';\n} else if (source.status === 'possible_duplicate') {\n  text = 'Похоже, это дубль документа.';\n} else if (source.status === 'processing_error') {\n  text = 'Обработка завершилась ошибкой.';\n}\nif (source.review_id) {\n  text += `\\nID проверки: ${source.review_id}`;\n}\nif (source.result_code) {\n  text += `\\nРезультат: ${source.result_code}`;\n}\nif (source.error_text) {\n  text += `\\nОшибка: ${source.error_text}`;\n}\nreturn [{ json: { ...source, replyText: text } }];"
      },
