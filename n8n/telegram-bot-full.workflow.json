        "jsCode": "const store = $getWorkflowStaticData('global');\nstore.telegramBotSessions = store.telegramBotSessions || {};\nconst sessions = store.telegramBotSessions;\nconst session = sessions[$json.chatId];\nif (!session) {\n  return [{ json: { ...$json, statusLookupError: 'Пока нечего проверять. Сначала отправьте фото или PDF.' } }];\n}\nif (!session.backendUploadId) {\n  return [{ json: { ...$json, statusLookupError: 'Документ ещё не отправлен в backend. Нажмите «Готово» после загрузки страниц.' } }];\n}\nreturn [{ json: { ...$json, backendUploadId: session.backendUploadId } }];"
