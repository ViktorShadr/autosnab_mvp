      "parameters": {
        "jsCode": "const session = $json.data?.[0] || null;\nif (!session?.id) {\n  return [{ json: { ...$json, statusLookupError: 'Пока нечего проверять. Сначала отправьте фото или PDF.' } }];\n}\nif (!session.backend_upload_id) {\n  return [{ json: { ...$json, statusLookupError: 'Документ ещё не отправлен в backend. Нажмите «Готово» после загрузки страниц.' } }];\n}\nreturn [{ json: { ...$json, backendUploadId: session.backend_upload_id } }];"
      },
