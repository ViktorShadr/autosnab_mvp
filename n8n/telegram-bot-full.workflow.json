      "parameters": {
        "jsCode": "const msg = $json.message || {};\nconst text = String(msg.text || '').trim();\nconst normalizedText = text.toLowerCase();\nconst chatId = msg.chat?.id ? String(msg.chat.id) : null;\nconst userId = msg.from?.id ? String(msg.from.id) : null;\nconst username = msg.from?.username || [msg.from?.first_name, msg.from?.last_name].filter(Boolean).join(' ') || null;\nconst photo = Array.isArray(msg.photo) && msg.photo.length ? msg.photo[msg.photo.length - 1] : null;\nconst document = msg.document || null;\nconst fileId = document?.file_id || photo?.file_id || null;\nconst fileName = document?.file_name || (photo ? `telegram-photo-${photo.file_unique_id || Date.now()}.jpg` : null);\nconst mimeType = document?.mime_type || (photo ? 'image/jpeg' : null);\nconst config = {\n  telegramBotToken: 'replace_me',\n  backendBaseUrl: 'http://localhost:8000',\n  botSourceChannel: 'telegram_bot',\n  botDocumentKind: 'primary_document',\n  createGoogleSheet: 'false',\n  extractionMethod: 'openai',\n  defaultOrganizationName: '',\n  defaultPointName: ''\n};\nconst homeText = [\n  'АвтоСнаб Документы',\n  '',\n  'Отправьте фото или PDF накладной.',\n  'Если страниц несколько, пришлите их подряд.',\n  'Когда всё отправите, нажмите «Готово».'\n].join('\\n');\nconst menuText = 'Команды: Новый документ · Готово · Статус · Сбросить';\nconst welcomeText = `${homeText}\\n\\n${menuText}`;\nconst helpText = 'Новый документ · Готово · Статус · Сбросить';\nconst collectingHint = 'Следующий шаг: отправьте ещё страницу или нажмите «Готово».';\nlet intent = 'unknown';\nif (['/start', '/menu', '/help', 'меню', 'начать', 'новый документ', 'новый', 'загрузить'].includes(normalizedText)) intent = 'start_session';\nelse if (normalizedText === 'готово' || normalizedText === '/done') intent = 'finalize';\nelse if (normalizedText === 'статус' || normalizedText === '/status') intent = 'status';\nelse if (normalizedText === 'сбросить' || normalizedText === '/reset') intent = 'reset';\nelse if (fileId) intent = 'append_file';\nreturn [{ json: { intent, text, normalizedText, config, homeText, welcomeText, helpText, collectingHint, chatId, userId, username, fileId, fileName, mimeType, raw: $json } }];"
      },
