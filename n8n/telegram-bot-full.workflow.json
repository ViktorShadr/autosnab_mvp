    {
      "parameters": {
        "jsCode": "const config = $json.config || {};\nif (!$json.chatId) {\n  return [{ json: { ...$json, appendError: 'Не найден chatId для загрузки файла.' } }];\n}\nif (!$json.fileId) {\n  return [{ json: { ...$json, appendError: 'Файл не найден в сообщении Telegram.' } }];\n}\nconst sessionRow = $json.data?.[0] || null;\nlet sessionFilesJson = '[]';\nlet sessionStatus = 'collecting';\nlet organizationName = config.defaultOrganizationName || '';\nlet pointName = config.defaultPointName || '';\nlet backendUploadId = '';\nlet backendTraceId = '';\nif (sessionRow) {\n  sessionFilesJson = sessionRow.files_json || '[]';\n  sessionStatus = sessionRow.status || sessionStatus;\n  organizationName = sessionRow.organization_name || organizationName;\n  pointName = sessionRow.point_name || pointName;\n  backendUploadId = sessionRow.backend_upload_id || '';\n  backendTraceId = sessionRow.backend_trace_id || '';\n}\nlet existingFilesCount = 0;\ntry {\n  const parsed = JSON.parse(sessionFilesJson || '[]');\n  existingFilesCount = Array.isArray(parsed) ? parsed.length : 0;\n} catch {\n  sessionFilesJson = '[]';\n}\nreturn [{ json: { ...$json, sessionRowId: sessionRow?.id || '', sessionFilesJson, sessionStatus, sessionAutoOpened: existingFilesCount === 0, organizationName, pointName, backendUploadId, backendTraceId } }];"
      },
