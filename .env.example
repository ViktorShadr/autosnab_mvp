DATABASE_URL=sqlite:///./autosnab_mvp.db

# Google OAuth user authorization.
# Создайте OAuth Client ID типа Web application и заполните client credentials.
GOOGLE_AUTH_MODE=oauth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_ACCESS_TOKEN=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_TOKEN_EXPIRY=
GOOGLE_OAUTH_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/google-oauth/callback
# If the backend is published through ngrok for a cloud n8n workflow,
# switch both GOOGLE_OAUTH_REDIRECT_URI and PUBLIC_API_BASE_URL to the same
# public HTTPS domain, for example:
# GOOGLE_OAUTH_REDIRECT_URI=https://example.ngrok-free.app/api/v1/google-oauth/callback
# Same idea for a VPS deploy behind the `caddy` compose profile (no purchased
# domain, real HTTPS via nip.io + Let's Encrypt):
# GOOGLE_OAUTH_REDIRECT_URI=https://203-0-113-5.nip.io/api/v1/google-oauth/callback
SECRETS_ENV_FILE=.env

# Google Drive OCR + Google Sheets API.
# Google Vision API и Google Apps Script не используются.
GOOGLE_DRIVE_OCR_ENABLED=true
GOOGLE_DRIVE_OCR_LANGUAGE=ru
GOOGLE_DRIVE_OCR_DELETE_TEMP_FILES=true
GOOGLE_DRIVE_OCR_FOLDER_ID=
# Drive's OCR-on-upload conversion is async; export can race ahead of it and
# return an empty document. These retry the export until real text appears.
GOOGLE_DRIVE_OCR_EXPORT_RETRY_ATTEMPTS=6
GOOGLE_DRIVE_OCR_EXPORT_RETRY_DELAY_SECONDS=4.0
GOOGLE_DRIVE_OCR_MIN_TEXT_LENGTH=20
GOOGLE_API_RETRY_ATTEMPTS=3
GOOGLE_API_RETRY_BACKOFF_SECONDS=0.5
GOOGLE_SHEETS_ENABLED=true
GOOGLE_APPS_SCRIPT_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CONVERSION_EXCEPTIONS_SHEET_NAME=
PUBLIC_API_BASE_URL=http://localhost:8000
# Example public value for cloud n8n via ngrok: https://example.ngrok-free.app
# Example public value for a VPS deploy via the `caddy` profile (no domain
# purchase needed, matches PUBLIC_DOMAIN below): https://203-0-113-5.nip.io
UPLOADED_INVOICES_DIR=uploads/invoices
NGROK_AUTHTOKEN=
# VPS deploy without a purchased domain: `docker compose --profile public-ip
# up --build -d` starts an extra `caddy` reverse-proxy service that gets a
# real Let's Encrypt certificate for a nip.io hostname pointing at this
# server's own public IP - no DNS setup, no self-signed-cert warnings in n8n.
# Set this to <ip-with-dashes>.nip.io, e.g. 203-0-113-5.nip.io for
# 203.0.113.5. Requires inbound port 80 open on the VPS (used only for the
# Let's Encrypt HTTP-01 challenge, independent of which port serves traffic).
PUBLIC_DOMAIN=
# If the VPS's port 443 is already used by another service, publish Caddy's
# HTTPS on a different host port instead (Caddy itself still just serves its
# normal internal 443 - only the host-side mapping changes). Leave unset to
# use 443. If set, PUBLIC_API_BASE_URL/GOOGLE_OAUTH_REDIRECT_URI must include
# the same port, e.g. https://203-0-113-5.nip.io:8443
CADDY_HTTPS_HOST_PORT=
# Optional memory cap for the backend container on a small/shared VPS that
# also runs other services, so a memory spike here cannot OOM-kill them.
# Format matches `docker run --memory`, e.g. 700m. Leave unset (no limit) on
# a dedicated machine.
BACKEND_MEM_LIMIT=
# Required once the backend is reachable through a public ngrok/Caddy URL:
# all /bot/* endpoints then require header X-Bot-Api-Key to match this value.
# Leave empty only for local-only development without a public tunnel.
BOT_API_SHARED_SECRET=

# Native Telegram bot (replaces the old n8n workflow). Set TELEGRAM_BOT_ENABLED=true
# and provide the BotFather token to start long-polling from the backend process.
# Never run this alongside the n8n workflow against the same bot token at once.
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
# Must outlast worst-case backend processing (OpenAI 180s + 240s retry + OCR/write
# overhead, ~420-450s) or the bot stops watching before the pipeline finishes and
# never delivers the final result automatically. 120 * 5s = 600s.
TELEGRAM_BOT_POLL_INTERVAL_SECONDS=5.0
TELEGRAM_BOT_MAX_POLL_ATTEMPTS=120

# Evidence extraction and OpenAI structured parser.
DOCUMENT_EXTRACTION_BACKEND=openai
DOCUMENT_EXTRACTION_FALLBACK_TO_OCR=true
MINERU_COMMAND={python_executable} -m mineru.cli.client -p {file_path} -o {output_dir} -b pipeline -l cyrillic
MINERU_TIMEOUT_SECONDS=900

OPENAI_API_KEY=
OPENAI_INVOICE_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=minimal
OPENAI_TIMEOUT_SECONDS=180
OPENAI_TIMEOUT_RETRY_SECONDS=240
OPENAI_MAX_EVIDENCE_CHARS=120000
OPENAI_MAX_IMAGE_PAGES=12
OPENAI_MAX_IMAGE_BYTES=12000000
OPENAI_IMAGE_DETAIL=high
OPENAI_DEBUG_LOG_ENABLED=true
OPENAI_DEBUG_LOG_DIR=exports/openai_debug
INVOICE_ALLOW_HEADER_ONLY_DOCUMENTS=false
CONVERSION_AMOUNT_TOLERANCE=0.01

# iiko Server API incoming invoice integration
# Для реальной отправки включите true и заполните доступы iiko.
IIKO_INTEGRATION_ENABLED=false
IIKO_BASE_URL=
IIKO_LOGIN=
IIKO_PASSWORD_SHA1=
IIKO_TOKEN=
IIKO_TIMEOUT_SECONDS=30
IIKO_AUTO_MAPPING_ENABLED=true
IIKO_MAPPING_MIN_CONFIDENCE=0.72
IIKO_MAPPING_REVIEW_CONFIDENCE=0.55

# Diadoc automatic integration
DIADOC_INTEGRATION_ENABLED=false
DIADOC_API_BASE_URL=https://diadoc-api.kontur.ru
DIADOC_IDENTITY_BASE_URL=https://identity.kontur.ru
DIADOC_OAUTH_AUTHORIZE_URI=https://identity.kontur.ru/connect/authorize
DIADOC_OAUTH_TOKEN_URI=https://identity.kontur.ru/connect/token
DIADOC_OAUTH_REDIRECT_URI=https://<backend>/api/v1/diadoc/oauth/callback
DIADOC_OAUTH_SCOPE=openid profile email offline_access Diadoc.PublicAPI
DIADOC_CLIENT_ID=
DIADOC_CLIENT_SECRET=
DIADOC_ACCESS_TOKEN=
DIADOC_REFRESH_TOKEN=
DIADOC_TOKEN_EXPIRY=
DIADOC_BOX_ID=
DIADOC_DEPARTMENT_ID=
# Optional comma-separated typeNamedId filter. Leave empty to process supported inbound types.
DIADOC_TYPE_NAMED_IDS=
DIADOC_TIMEOUT_SECONDS=30
DIADOC_SYNC_LIMIT=100
DIADOC_DOCUMENTS_DIR=uploads/diadoc
DIADOC_SCHEDULER_ENABLED=true
DIADOC_SYNC_INTERVAL_SECONDS=300
DIADOC_RETRY_MAX_ATTEMPTS=5
DIADOC_RETRY_BASE_DELAY_SECONDS=60
DIADOC_RETRY_BATCH_SIZE=50
DIADOC_DELIVERY_STALE_SECONDS=600
DIADOC_SYNC_LEASE_SECONDS=1800
# latest skips historical events on the first run; use oldest only for an intentional backfill.
DIADOC_INITIAL_SYNC_MODE=latest
DIADOC_MAX_PAGES_PER_SYNC=10
DIADOC_HTTP_RETRY_ATTEMPTS=4
DIADOC_HTTP_RETRY_BASE_DELAY_SECONDS=1
DIADOC_HTTP_RETRY_MAX_DELAY_SECONDS=30
DIADOC_MAX_ATTACHMENT_BYTES=100000000
DIADOC_MAX_XML_BYTES=20000000
DIADOC_GENERATE_PRINT_FORM=true
DIADOC_PRINT_FORM_ATTEMPTS=5
DIADOC_DOWNLOAD_ALL_ATTACHMENTS=true
DIADOC_PARSE_UNSTRUCTURED_ATTACHMENTS=true
DIADOC_UNSTRUCTURED_EXTRACTION_METHOD=openai
# Protects Diadoc status/sync/retry/OAuth management endpoints.
# If empty, BOT_API_SHARED_SECRET is used; if both are empty, protection is disabled for local development.
DIADOC_ADMIN_API_KEY=

# SBIS (Saby) JSON-RPC integration. Login/password session auth (SID), not OAuth.
SBIS_INTEGRATION_ENABLED=false
SBIS_API_BASE_URL=https://online.sbis.ru
SBIS_AUTH_URL=https://online.sbis.ru/auth/service/
SBIS_LOGIN=
SBIS_PASSWORD=
# Only needed if the account has multiple organizations/cabinets.
SBIS_ACCOUNT_NUMBER=
SBIS_TIMEOUT_SECONDS=30
SBIS_SYNC_LIMIT=100
SBIS_DOCUMENTS_DIR=uploads/sbis
SBIS_SCHEDULER_ENABLED=true
SBIS_SYNC_INTERVAL_SECONDS=300
SBIS_RETRY_MAX_ATTEMPTS=5
SBIS_RETRY_BASE_DELAY_SECONDS=60
SBIS_RETRY_BATCH_SIZE=50
SBIS_DELIVERY_STALE_SECONDS=600
SBIS_SYNC_LEASE_SECONDS=1800
SBIS_MAX_PAGES_PER_SYNC=10
# How far back to look on the very first sync (no stored cursor yet).
SBIS_INITIAL_SYNC_DAYS_BACK=7
# Comma-separated Документ.Тип filter — накладные/УПД (ДокОтгрВх) и счета (СчетВх).
SBIS_DOCUMENT_TYPES=ДокОтгрВх,СчетВх
SBIS_HTTP_RETRY_ATTEMPTS=4
SBIS_HTTP_RETRY_BASE_DELAY_SECONDS=1
SBIS_HTTP_RETRY_MAX_DELAY_SECONDS=30
SBIS_MAX_ATTACHMENT_BYTES=100000000
# Protects SBIS status/sync/retry endpoints; falls back to BOT_API_SHARED_SECRET if empty.
SBIS_ADMIN_API_KEY=
SBIS_PARSE_UNSTRUCTURED_ATTACHMENTS=true
SBIS_UNSTRUCTURED_EXTRACTION_METHOD=openai
