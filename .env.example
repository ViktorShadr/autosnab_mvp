DATABASE_URL=sqlite:///./autosnab_mvp.db

# Google OAuth user authorization.
# Создайте OAuth Client ID типа Web application и заполните client credentials.
GOOGLE_AUTH_MODE=oauth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_ACCESS_TOKEN=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_TOKEN_EXPIRY=
GOOGLE_OAUTH_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/google-oauth/callback
# If the backend is published through ngrok for a cloud n8n workflow,
# switch both GOOGLE_OAUTH_REDIRECT_URI and PUBLIC_API_BASE_URL to the same
# public HTTPS domain, for example:
# GOOGLE_OAUTH_REDIRECT_URI=https://example.ngrok-free.app/api/v1/google-oauth/callback
# Same idea for a VPS deploy behind the `caddy` compose profile (no purchased
# domain, real HTTPS via nip.io + Let's Encrypt):
# GOOGLE_OAUTH_REDIRECT_URI=https://203-0-113-5.nip.io/api/v1/google-oauth/callback
SECRETS_ENV_FILE=.env

# Google Drive OCR + Google Sheets API.
# Google Vision API и Google Apps Script не используются.
GOOGLE_DRIVE_OCR_ENABLED=true
GOOGLE_DRIVE_OCR_LANGUAGE=ru
GOOGLE_DRIVE_OCR_DELETE_TEMP_FILES=true
GOOGLE_DRIVE_OCR_FOLDER_ID=
# Drive's OCR-on-upload conversion is async; export can race ahead of it and
# return an empty document. These retry the export until real text appears.
GOOGLE_DRIVE_OCR_EXPORT_RETRY_ATTEMPTS=6
GOOGLE_DRIVE_OCR_EXPORT_RETRY_DELAY_SECONDS=4.0
GOOGLE_DRIVE_OCR_MIN_TEXT_LENGTH=20
GOOGLE_API_RETRY_ATTEMPTS=3
GOOGLE_API_RETRY_BACKOFF_SECONDS=0.5
GOOGLE_SHEETS_ENABLED=true
GOOGLE_APPS_SCRIPT_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CONVERSION_EXCEPTIONS_SHEET_NAME=
PUBLIC_API_BASE_URL=http://localhost:8000
# Example public value for cloud n8n via ngrok: https://example.ngrok-free.app
# Example public value for a VPS deploy via the `caddy` profile (no domain
# purchase needed, matches PUBLIC_DOMAIN below): https://203-0-113-5.nip.io
UPLOADED_INVOICES_DIR=uploads/invoices
NGROK_AUTHTOKEN=
# VPS deploy without a purchased domain: `docker compose --profile public-ip
# up --build -d` starts an extra `caddy` reverse-proxy service that gets a
# real Let's Encrypt certificate for a nip.io hostname pointing at this
# server's own public IP - no DNS setup, no self-signed-cert warnings in n8n.
# Set this to <ip-with-dashes>.nip.io, e.g. 203-0-113-5.nip.io for
# 203.0.113.5. Requires inbound ports 80/443 open on the VPS.
PUBLIC_DOMAIN=
# Required once the backend is reachable through a public ngrok/Caddy URL:
# all /bot/* endpoints then require header X-Bot-Api-Key to match this value.
# Leave empty only for local-only development without a public tunnel.
BOT_API_SHARED_SECRET=

# Evidence extraction and OpenAI structured parser.
DOCUMENT_EXTRACTION_BACKEND=openai
DOCUMENT_EXTRACTION_FALLBACK_TO_OCR=true
MINERU_COMMAND={python_executable} -m mineru.cli.client -p {file_path} -o {output_dir} -b pipeline -l cyrillic
MINERU_TIMEOUT_SECONDS=900

OPENAI_API_KEY=
OPENAI_INVOICE_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_EVIDENCE_CHARS=120000
OPENAI_MAX_IMAGE_PAGES=12
OPENAI_MAX_IMAGE_BYTES=12000000
OPENAI_IMAGE_DETAIL=high
OPENAI_DEBUG_LOG_ENABLED=true
OPENAI_DEBUG_LOG_DIR=exports/openai_debug
INVOICE_ALLOW_HEADER_ONLY_DOCUMENTS=false
CONVERSION_AMOUNT_TOLERANCE=0.01

# iiko Server API incoming invoice integration
# Для реальной отправки включите true и заполните доступы iiko.
IIKO_INTEGRATION_ENABLED=false
IIKO_BASE_URL=
IIKO_LOGIN=
IIKO_PASSWORD_SHA1=
IIKO_TOKEN=
IIKO_TIMEOUT_SECONDS=30
IIKO_AUTO_MAPPING_ENABLED=true
IIKO_MAPPING_MIN_CONFIDENCE=0.72
